{
  "manifest_version": 3,
  "name": "随页",
  "short_name": "随页",
  "version": "0.1.1",
  "description": "集网页调试、内容处理与效率工具于一体的可扩展浏览器侧边工具箱。",
  "permissions": ["sidePanel", "storage", "declarativeNetRequest", "debugger", "tabs", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": {
    "default_title": "打开随页",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
